---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
	title: string;
	bodyclass: string;
}

const { title, bodyclass } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="appvertix" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<link rel="stylesheet" href={`${import.meta.env.BASE_URL}assets/css/plugins/fontawesome-6.css`} />
		<link rel="stylesheet" href={`${import.meta.env.BASE_URL}assets/css/plugins/swiper.min.css`} />
		<link rel="stylesheet" href={`${import.meta.env.BASE_URL}assets/css/vendor/metismenu.css`} />
		<link rel="stylesheet" href={`${import.meta.env.BASE_URL}assets/css/plugins/animate.min.css`} />
		<link rel="stylesheet" href={`${import.meta.env.BASE_URL}assets/css/vendor/bootstrap.min.css`} />
		<link rel="stylesheet" href={`${import.meta.env.BASE_URL}assets/css/style.css`} />
		<title>Appvertix | {title}</title>
	</head>

	<body class={bodyclass}>
		{bodyclass.includes("coming-soon") ? "" : <Header />}

		<div id="smooth-wrapper">
			<div id="smooth-content">
				<slot />
				{bodyclass.includes("coming-soon") ? "" : <Footer bodyclass={bodyclass} />}
			</div>
		</div>
	</body>

	<script defer src={`${import.meta.env.BASE_URL}assets/js/vendor/jquery.min.js`}></script>
	<script defer src={`${import.meta.env.BASE_URL}assets/js/plugins/bootstrap.min.js`}></script>
	<script defer src={`${import.meta.env.BASE_URL}assets/js/plugins/contact.form.js`}></script>
	<script defer src={`${import.meta.env.BASE_URL}assets/js/vendor/waypoint.js`}></script>
	<script defer src={`${import.meta.env.BASE_URL}assets/js/plugins/swiper.js`}></script>
	<script defer src={`${import.meta.env.BASE_URL}assets/js/plugins/resizer-sensor.js`}></script>
	<script defer src={`${import.meta.env.BASE_URL}assets/js/plugins/sticky-sidebar.js`}></script>
	<script defer src={`${import.meta.env.BASE_URL}assets/js/plugins/isotop.js`}></script>
	<script defer src={`${import.meta.env.BASE_URL}assets/js/plugins/imagesloaded.pkgd.min.js`}></script>
	<script defer src={`${import.meta.env.BASE_URL}assets/js/plugins/smoothscroll-varticle.js`}></script>
	<script defer src={`${import.meta.env.BASE_URL}assets/js/vendor/gsap.js`}></script>
	<script defer src={`${import.meta.env.BASE_URL}assets/js/plugins/scrolltiger.js`}></script>
	<script defer src={`${import.meta.env.BASE_URL}assets/js/plugins/scrolltoplugin.js`}></script>
	<script defer src={`${import.meta.env.BASE_URL}assets/js/plugins/splittext.js`}></script>
	<script defer src={`${import.meta.env.BASE_URL}assets/js/plugins/smoothscroll.js`}></script>
	<script defer src={`${import.meta.env.BASE_URL}assets/js/plugins/scrollmagic.js`}></script>
	<script defer src={`${import.meta.env.BASE_URL}assets/js/plugins/animate-scrollmagic.js`}></script>
	<script defer src={`${import.meta.env.BASE_URL}assets/js/plugins/tilt.js`}></script>
	<script defer src={`${import.meta.env.BASE_URL}assets/js/plugins/counterup.js`}></script>
	<script defer src={`${import.meta.env.BASE_URL}assets/js/vendor/waw.js`}></script>
	<script defer src={`${import.meta.env.BASE_URL}assets/js/main.js`}></script>
</html>
