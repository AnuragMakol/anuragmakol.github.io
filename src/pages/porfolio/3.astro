---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Welcome to Astro" bodyclass="inner-page">
    <div class="portfolio-large-img-and-top-title">
        <div class="container">
            <div class="row">
                <div class="col-lg-12 ptb--140 ptb_md--60 ptb_sm--20">
                    <div class="title-areas-wrapper-pd pt--120">
                        <div class="left-area">
                            <h1 class="title rts_hero__title"> Converted Portfolio <br /> Animation </h1>
                            <div class="bottom-area">
                                <div class="single-categoiry">
                                    <p class="light">Category</p>
                                    <span>Multonia Milano</span>
                                </div>
                                <div class="single-categoiry">
                                    <p class="light">Year</p>
                                    <span>Start 2023</span>
                                </div>
                                <div class="single-categoiry">
                                    <p class="light">Role</p>
                                    <span>Branding</span>
                                </div>
                                <div class="single-categoiry">
                                    <p class="light">Category</p>
                                    <span>www.creatoma.com</span>
                                </div>
                            </div>
                        </div>
                        <div class="right rts-scroll-down-circle-wrapper-3">
                            <a href="#" class="speen-shape scroll-down-circle-3" >
                                <svg class="uni-circle-text-path uk-text-secondary uni-animation-spin" viewBox="0 0 100 100" width="140" height="140" >
                                    <defs>
                                        <path id="circle" d="M 50, 50 m -37, 0 a 37,37 0 1,1 74,0 a 37,37 0 1,1 -74,0" > </path>
                                    </defs>
                                    <text font-size="11.75">
                                        <textPath xlink:href="#circle" >Project SHowcase • Project SHowcase •</textPath >
                                    </text>
                                </svg>
                                <i class="fa-solid fa-star-sharp"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="rts-portfolio-details-img-bottom rts-section-gapBottom">
        <div class="container">
            <div class="row h-100">
                <div class="col-lg-6 rts-sticky-column-item">
                    <div class="left-pd-image-bt-content small-cn">
                        <h3 class="title">Portfolio Description</h3>
                        <p class="disc"> Habitant libero ultricies fusce lacus fermentum augue nulla euismod penatibus quis nam netus, posuere tortor condimentum pulvinar rutrum ad diam cubilia tempor sem. Lobortis cubilia diam suscipit massa suspendisse vitae, eu lectus neque ridiculus facilisis curae interdum, augue. Non ut porttitor nostra id accumsan habitant arcu, nullam venenatis facilisi primis penatibus consequat bibendum mollis, lacus ad erat pulvinar ligula etiam. Nullam ullamcorper et habitasse vestibulum nibh venenatis torquent. </p>
                        <div class="bottom-content">
                            <h6 class="title">Tasks We Done</h6>
                            <p class="dsic"> Neque aliquam eget inceptos et senectus laoreet curabitur, justo luctus sagittis tincidunt per potenti. Blandit ornare sagittis faucibus interdum nam sodales cum. </p>
                            <div class="stratagy-wrapper">
                                <div class="single-staratagy">
                                    <h6 class="title">Strategy</h6>
                                    <p>Branding, UI/UX Design</p>
                                </div>
                                <div class="single-staratagy">
                                    <h6 class="title">Design</h6>
                                    <p>Branding, UI/UX Design</p>
                                </div>
                                <div class="single-staratagy">
                                    <h6 class="title">Client</h6>
                                    <p>Branding, UI/UX Design</p>
                                </div>
                            </div>
                            <button class="rts-btn btn-white mt--60" >Open Project</button >
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 pl--100 pl_md--15 pl_sm--10 pt_sm--50">
                    <div class="img-wrap-main-pd-varticle">
                        <div class="inner">
                            <div class="large-img">
                                <img src={`${import.meta.env.BASE_URL}assets/images/product/57.jpg`} alt="product" />
                            </div>
                            <div class="large-img">
                                <img src={`${import.meta.env.BASE_URL}assets/images/product/59.jpg`} alt="product" />
                            </div>
                            <div class="large-img">
                                <img src={`${import.meta.env.BASE_URL}assets/images/product/58.jpg`} alt="product" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="rts-contact-form-pd rts-section-gap">
        <div class="container">
            <div class="row">
                <div class="row">
                    <div class="col-lg-12">
                        <div class="title-area-pd">
                            <h2 class="title quote">Contact With Us</h2>
                            <p class="rts-text-anim"> Your email address will not be published. Required fields are marked * </p>
                        </div>
                    </div>
                </div>
                <div class="row mt--60">
                    <div class="col-lg-12">
                        <form action="#" class="product-details-form">
                            <div class="row">
                                <div class="col-lg-4">
                                    <div class="single-input rts-slide-up-gsap">
                                        <label for="name">Name*</label>
                                        <input id="name" type="text" required />
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="single-input rts-slide-up-gsap">
                                        <label for="email">Email*</label>
                                        <input id="email" type="email" />
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="single-input rts-slide-up-gsap">
                                        <label for="website">Website*</label>
                                        <input id="website" type="text" />
                                    </div>
                                </div>
                                <div class="col-gl-12 mt--30">
                                    <div class="single-input rts-slide-up-gsap">
                                        <label for="message">Comment*</label>
                                        <textarea id="message"></textarea>
                                    </div>
                                </div>
                            </div>
                            <button class="submit-pd">Conmtact Me</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>
